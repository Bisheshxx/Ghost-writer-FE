{
  "openapi": "3.0.0",
  "info": {
    "title": "Ghost API",
    "version": "1.0.0",
    "description": "TypeScript Express API for resume, cover letter, profile, and job tracker workflows."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current server"
    }
  ],
  "tags": [
    {
      "name": "Health"
    },
    {
      "name": "Jobs"
    },
    {
      "name": "Cover Letter"
    },
    {
      "name": "Experience"
    },
    {
      "name": "Projects"
    },
    {
      "name": "Qualifications"
    },
    {
      "name": "Skills"
    },
    {
      "name": "Webhooks"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Clerk bearer token"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "code": {
                "type": "string"
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "JobStatus": {
        "type": "string",
        "enum": [
          "Empty",
          "Generated",
          "Applied",
          "Accepted",
          "Rejected",
          "Interview stage"
        ]
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "65f000000000000000000001"
          },
          "company": {
            "type": "string",
            "example": "Acme"
          },
          "title": {
            "type": "string",
            "example": "Backend Engineer"
          },
          "description": {
            "type": "string",
            "example": "Build APIs"
          },
          "location": {
            "type": "string",
            "example": "Remote"
          },
          "link": {
            "type": "string",
            "example": "https://example.com/jobs/backend-engineer"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "JobInput": {
        "type": "object",
        "required": [
          "company",
          "title",
          "description",
          "location",
          "link"
        ],
        "properties": {
          "company": {
            "type": "string",
            "example": "Acme"
          },
          "title": {
            "type": "string",
            "example": "Backend Engineer"
          },
          "description": {
            "type": "string",
            "example": "Build APIs"
          },
          "location": {
            "type": "string",
            "example": "Remote"
          },
          "link": {
            "type": "string",
            "example": "https://example.com/jobs/backend-engineer"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          }
        }
      },
      "JobGeneratedContent": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "resumeText": {
            "type": "string"
          },
          "coverLetterText": {
            "type": "string"
          },
          "model": {
            "type": "string",
            "example": "llama-3.1-8b-instant"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ExperienceInput": {
        "type": "object",
        "required": [
          "companyName",
          "jobTitle",
          "Descriptions",
          "startDate",
          "isCurrent"
        ],
        "properties": {
          "companyName": {
            "type": "string",
            "example": "Acme"
          },
          "jobTitle": {
            "type": "string",
            "example": "Backend Engineer"
          },
          "Descriptions": {
            "type": "string",
            "example": "Built APIs"
          },
          "startDate": {
            "type": "string",
            "example": "2024-01"
          },
          "isCurrent": {
            "type": "boolean",
            "example": true
          },
          "endDate": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "relavantDetails": {
            "type": "string",
            "nullable": true,
            "example": "Promoted within first year"
          }
        }
      },
      "ProjectInput": {
        "type": "object",
        "required": [
          "projectTitle",
          "stack"
        ],
        "properties": {
          "projectTitle": {
            "type": "string",
            "example": "Resume Builder"
          },
          "details": {
            "type": "string",
            "example": "Built a resume editor"
          },
          "stack": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Node",
              "React"
            ]
          }
        }
      },
      "QualificationInput": {
        "type": "object",
        "required": [
          "qualification",
          "descriptions",
          "startDate",
          "isCurrent",
          "instituteName"
        ],
        "properties": {
          "qualification": {
            "type": "string",
            "example": "BSc Computer Science"
          },
          "descriptions": {
            "type": "string",
            "example": "Software engineering"
          },
          "startDate": {
            "type": "string",
            "example": "2020-09"
          },
          "isCurrent": {
            "type": "boolean",
            "example": false
          },
          "endDate": {
            "type": "string",
            "nullable": true,
            "example": "2024-06"
          },
          "instituteName": {
            "type": "string",
            "example": "Example University"
          },
          "relavantDetails": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "CoverLetterInput": {
        "type": "object",
        "required": [
          "jobDescription"
        ],
        "properties": {
          "jobDescription": {
            "type": "string",
            "example": "Software Engineer role at Acme."
          }
        }
      },
      "SkillsInput": {
        "type": "object",
        "properties": {
          "technicalSkills": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "category": {
                  "type": "string",
                  "example": "Frontend"
                },
                "technologies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "React",
                    "TypeScript"
                  ]
                }
              }
            }
          },
          "personalSkills": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "communication"
            ]
          },
          "awards": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "details": {
                  "type": "string"
                },
                "issuedDate": {
                  "type": "string",
                  "format": "date"
                },
                "issuer": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is active",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "example": "active"
                        },
                        "version": {
                          "type": "string",
                          "example": "1.0.0-ts"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2026-05-23T00:00:00.000Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs": {
      "get": {
        "tags": [
          "Jobs"
        ],
        "summary": "List authenticated user's jobs",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/JobStatus"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Job"
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "page": {
                          "type": "integer"
                        },
                        "limit": {
                          "type": "integer"
                        },
                        "total": {
                          "type": "integer"
                        },
                        "totalPages": {
                          "type": "integer"
                        },
                        "hasNextPage": {
                          "type": "boolean"
                        }
                      }
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2026-05-23T00:00:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "Jobs"
        ],
        "summary": "Create a job",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created job",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Job"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2026-05-23T00:00:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
